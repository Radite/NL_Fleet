# Copy to .env and fill in what you need — nothing here is required to run
# the app in mock mode. See README.md for the full explanation of each.

# Required to switch from mock mode (pattern-matched fake responses) to real
# Claude API calls. Leave unset to keep running fully offline in mock mode.
ANTHROPIC_API_KEY=

# Optional. Shared-secret value clients must send as the X-API-Key header on
# /ask. Leave unset for no auth (fine for local dev; logs a warning on every
# request so an open deployment doesn't go unnoticed). Not needed if you're
# deploying behind Azure App Service Easy Auth instead — see README.
APP_API_KEY=

# Optional. Max requests per client IP per 60-second window on /ask.
# Defaults to 20 if unset.
APP_RATE_LIMIT=20

# Optional. Selects the DB backend: "sqlite" (default, bundled demo db) or
# "sqlserver" (real production reconciliation DB via pyodbc — requires
# DB_CONNECTION_STRING below and `pip install pyodbc`).
DB_BACKEND=sqlite

# Required only when DB_BACKEND=sqlserver. Full pyodbc connection string for
# the read-only fleet_nl_reader login. Not used, and not needed, for sqlite.
DB_CONNECTION_STRING=

# Optional. Max seconds a single query is allowed to run before timing out.
# Defaults to 10 if unset.
DB_QUERY_TIMEOUT_SECONDS=10
